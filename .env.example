# Copy to .env and edit. The .env file is gitignored.

# --- Core ---
AEGIS_ENV=production
AEGIS_HOST=0.0.0.0
AEGIS_PORT=8000

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
AEGIS_SECRET_KEY=replace-me-with-a-48-byte-url-safe-token
AEGIS_SESSION_TTL_HOURS=168
AEGIS_COOKIE_SECURE=false           # set true once HTTPS is in front of it
AEGIS_COOKIE_DOMAIN=

# --- Storage ---
# Override only if you want data outside the repo (e.g. on an SSD mount).
# AEGIS_DATA_DIR=/srv/aegisnotes/data

# --- Upload limits ---
AEGIS_MAX_UPLOAD_MB=50
AEGIS_ALLOWED_MIME=image/jpeg,image/png,image/webp,image/tiff,application/pdf

# --- Logging ---
AEGIS_LOG_LEVEL=INFO
AEGIS_LOG_TO_FILE=true
